      },
      "teacher_supply": {
        "sheet": "教师供给",
        "columns": {
          "teacher_id": "教师标识",
          "campus": "校区",
          "class_type": "班型",
          "month": "月份",
          "time_slot": "峰值时段",
          "max_concurrent_classes": "并发班级上限"
        }
      },
      "room_supply": {
        "sheet": "教室供给",
        "columns": {
          "room_id": "教室标识",
          "campus": "校区",
          "room_type": "教室类型",
          "month": "月份",
          "time_slot": "峰值时段",
          "available": "是否可用"
        }
      }
    }
  }
